
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wise Gun - Registration & Map</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <link rel="stylesheet" href="style.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'dark-bg': '#262626',
                        'darker-bg': '#1a1a1a',
                        'accent-gold': '#c89f3e', 
                        'light-text': '#e0e0e0',
                    },
                }
            }
        }
    </script>
</head>

<body class="bg-darker-bg font-sans min-h-screen flex flex-col">

    <header class="sticky top-0 z-[1000] bg-dark-bg text-light-text shadow-xl">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <a href="index.html" class="text-xl font-bold tracking-wider text-accent-gold uppercase">WISE GUN</a>
            <nav class="hidden md:flex space-x-6 text-sm font-medium">
                <a href="index.html" class="hover:text-accent-gold transition-colors">Home</a> 
                <a href="Wisegun2.html" class="hover:text-accent-gold transition-colors">About</a> 
                <a href="Wisegun3.html" class="hover:text-accent-gold transition-colors">Safety</a> 
                <a href="Wisegun4.html" class="text-accent-gold">Registration</a> 
            </nav>
            <button onclick="handleRegistration()" class="py-2 px-4 bg-accent-gold text-darker-bg font-bold rounded text-sm btn-animate">
                LOG IN
            </button>
        </div>
    </header>

    <main class="flex-grow container mx-auto px-4 py-12">
        
        <div class="mb-10">
            <h1 class="text-brand-gold text-3xl font-bold uppercase tracking-widest border-l-4 border-accent-gold pl-4">
                Registration & Shop Locator
            </h1>
            <p class="text-gray-400 mt-2 text-sm">Find verified dealers and start your legal ownership journey.</p>
        </div>

        <section class="flex flex-col lg:flex-row gap-0 rounded-xl overflow-hidden shadow-2xl border border-white/5">
            
            <div id="map" class="w-full lg:w-3/5 h-[500px] bg-zinc-800">
                </div>

            <div class="w-full lg:w-2/5 bg-[#f3cc7a] p-8 flex flex-col justify-center">
                <div class="space-y-6 text-darker-bg">
                    <p class="font-bold italic text-lg leading-tight">
                        *take note: this gun shops in this map is only in calabarzon
                    </p>
                    <p class="font-medium italic text-sm border-l-2 border-black/20 pl-4">
                        *the other places outside the calabarzon is located in the Learn more in where you can locate verified gun shops.
                    </p>
                    <p class="font-medium italic text-sm border-l-2 border-black/20 pl-4">
                        *Just click the bottom words says learn more in the bottom of where you can find verified gun shops and then your free to roam.
                    </p>
                </div>

                <div class="mt-10">
                    <button onclick="handleRegistration()" class="w-full py-4 bg-darker-bg text-accent-gold font-black uppercase tracking-tighter hover:bg-black transition-all btn-animate shadow-xl">
                        Proceed to Registration
                    </button>
                </div>
            </div>
        </section>

    </main>

    <footer class="site-footer mt-20">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-[10px] text-gray-500 uppercase tracking-[0.3em] mb-4">
                Wise Gun © 2025 | Promoting Safe and Legal Firearm Ownership
            </p>
            <div class="h-[1px] w-full bg-white/5 mb-4"></div>
            <p class="text-xs text-gray-400">
                Contact: wisegun.info@gmail.com | Facebook: WiseGunPH
            </p>
        </div>
    </footer>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // 1. Map Logic
        document.addEventListener('DOMContentLoaded', function() {
            // Set view to Calabarzon region
            var map = L.map('map', {
                scrollWheelZoom: false // Prevents accidental scrolling while navigating page
            }).setView([14.2123, 121.1663], 9);

            L.tileLayer('https://{s}.tile.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            // Mock Data for verified shops
            var shopLocations = [
                { name: "Shooter Station", pos: [14.5995, 120.9842] },
                { name: "Bullet Weight Guns", pos: [14.5547, 121.0244] },
                { name: "Top Gun Sporting", pos: [14.2123, 121.1663] },
                { name: "R.B. Gun Store", pos: [14.3500, 120.9333] }
            ];

            // Custom Marker Style
            var customIcon = L.divIcon({
                className: 'custom-pin',
                html: `<div class="w-3 h-3 bg-accent-gold rounded-full border-2 border-white shadow-[0_0_10px_#c89f3e]"></div>`,
                iconSize: [12, 12]
            });

            shopLocations.forEach(shop => {
                L.marker(shop.pos, {icon: customIcon})
                 .addTo(map)
                 .bindPopup(`<b class="text-darker-bg">${shop.name}</b><br><span class="text-xs">Verified Dealer</span>`);
            });
        });

        // 2. Simple Registration Logic
        function handleRegistration() {
            const confirmRedirect = confirm("You are being redirected to the official PNP-FEO (Firearms and Explosives Office) website for legal registration. Continue?");
            if(confirmRedirect) {
                window.open("https://www.feo.pnp.gov.ph/", "_blank");
            }
        }

        lucide.createIcons();
    </script>
</body>
</html>
